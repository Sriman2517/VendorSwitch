@baseUrl = http://localhost:5000

### 1. POST /vendors - Register sample vendor
POST {{baseUrl}}/vendors
Content-Type: application/json

{
  "name": "VendorPANFast",
  "capability": "PAN_VERIFICATION",
  "enabled": true,
  "priority": 1,
  "weight": 70,
  "costPerRequest": 1.5,
  "timeoutMs": 2000,
  "rateLimitPerMinute": 100,
  "supportedFeatures": ["PAN_STATUS", "NAME_MATCH"],
  "endpointUrl": "",
  "health": {
    "status": "UP",
    "avgLatencyMs": 700,
    "successRate": 99,
    "errorRate": 1,
    "availability": 99
  }
}

### 2. GET /vendors - List vendors
GET {{baseUrl}}/vendors

### 3. POST /route - Route PAN verification request
POST {{baseUrl}}/route
Content-Type: application/json

{
  "capability": "PAN_VERIFICATION",
  "payload": {
    "pan": "ABCDE1234F",
    "name": "Rahul Sharma"
  },
  "requirements": {
    "maxLatencyMs": 2000,
    "requiredFeatures": ["PAN_STATUS", "NAME_MATCH"]
  }
}

### 4. GET /vendor-metrics - Vendor metrics
GET {{baseUrl}}/vendor-metrics

### 5. GET /routing-logs - Routing decision logs
GET {{baseUrl}}/routing-logs?limit=20

### 6. GET /health - Service health
GET {{baseUrl}}/health

### POST /routing-rules - Save routing rule
POST {{baseUrl}}/routing-rules
Content-Type: application/json

{
  "capability": "PAN_VERIFICATION",
  "strategy": "lowest_latency",
  "fallbackStrategy": "priority",
  "thresholds": {
    "maxLatencyMs": 2000,
    "maxErrorRate": 5,
    "minAvailability": 95
  },
  "enabled": true
}

### GET /routing-rules - List routing rules
GET {{baseUrl}}/routing-rules

### AI API - Generate routing rule
POST {{baseUrl}}/ai/generate-rule
Content-Type: application/json

{
  "prompt": "Use Lowest Latency for PAN Verification. If latency exceeds 2000ms or error rate exceeds 5%, fallback to Priority Routing. Minimum availability should be 95%."
}
